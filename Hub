end

local function LoadSettings()
    if isfile(FILE_NAME) then
        pcall(function()
            local data = HttpService:JSONDecode(readfile(FILE_NAME))
            for k, v in pairs(data) do _G.GeminiToggles[k] = v end
        end)
    end
end
