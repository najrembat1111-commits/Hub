-- --- AUTO DESTROY TURRET ---
local function getPlacedSentry()
    for _, obj in pairs(workspace:GetChildren()) do
        if string.find(obj.Name, "Sentry") and (obj:IsA("BasePart") or obj:IsA("Model")) then
            if obj:GetPivot().Position.Magnitude > 1 then return obj end
        end
    end
    return nil
end

task.spawn(function()
    local MEGA_SIZE = Vector3.new(2000, 2000, 2000)
    local DEPLOY_DELAY = 3.8
    local lastTarget = nil 

    while true do
        if _G.GeminiToggles.turret then
            local target = getPlacedSentry()
            if target and target ~= lastTarget then
                lastTarget = target
                task.wait(DEPLOY_DELAY)
                
                local char = LP.Character
                if target and target.Parent and char then
                    local backpack = LP:WaitForChild("Backpack")
                    local bat = backpack:FindFirstChild("Bat") or char:FindFirstChild("Bat")
                    local handle = bat and (bat:FindFirstChild("Handle") or bat:FindFirstChildWhichIsA("BasePart"))

                    if bat and handle then
                        bat.Parent = char
                        local originalSize = handle.Size
                        handle.Massless = true; handle.CanCollide = false; handle.Size = MEGA_SIZE; handle.Transparency = 0.8
                        
                        bat:Activate()
                        for i = 1, 25 do 
                            if not target.Parent then break end
                            if firetouchinterest then
                                firetouchinterest(target, handle, 0)
                                task.wait(0.01)
                                firetouchinterest(target, handle, 1)
                            end
                        end
                        
                        handle.Size = originalSize; handle.Transparency = 0; bat.Parent = backpack
                    end
                end
            end
            if lastTarget and not lastTarget.Parent then lastTarget = nil end
        end
        task.wait(0.1) 
    end
end)

