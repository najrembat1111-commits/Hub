local function AddToggle(parent, text, stateKey, callback)
    local Row = Instance.new("Frame", parent); Row.Size = UDim2.new(1, -10, 0, 45); Row.BackgroundColor3 = Color3.fromRGB(22, 22, 26); Instance.new("UICorner", Row)
    local Label = Instance.new("TextLabel", Row); Label.Text = text:upper(); Label.Size = UDim2.new(0.6, 0, 1, 0); Label.Position = UDim2.new(0, 12, 0, 0); Label.TextColor3 = Color3.new(1,1,1); Label.BackgroundTransparency = 1; Label.Font = Enum.Font.GothamBold; Label.TextSize = 11; Label.TextXAlignment = Enum.TextXAlignment.Left
    local Switch = Instance.new("TextButton", Row); Switch.Size = UDim2.new(0, 45, 0, 22); Switch.Position = UDim2.new(1, -55, 0.5, -11); Switch.BackgroundColor3 = Color3.fromRGB(40, 40, 45); Switch.Text = ""
    Instance.new("UICorner", Switch).CornerRadius = UDim.new(1, 0); local Dot = Instance.new("Frame", Switch); Dot.Size = UDim2.new(0, 18, 0, 18); Dot.Position = UDim2.new(0, 2, 0.5, -9); Dot.BackgroundColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    
    local function UpdateUI(act)
        Dot:TweenPosition(act and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9), "Out", "Quad", 0.1, true)
        Switch.BackgroundColor3 = act and ACCENT or Color3.fromRGB(40, 40, 45)
    end
    Switch.MouseButton1Click:Connect(function()
        _G.GeminiToggles[stateKey] = not _G.GeminiToggles[stateKey]
        UpdateUI(_G.GeminiToggles[stateKey]); SaveSettings()
        task.spawn(function() callback(_G.GeminiToggles[stateKey]) end)
    end)
    if _G.GeminiToggles[stateKey] == true then UpdateUI(true); task.spawn(function() callback(true) end) end
end

